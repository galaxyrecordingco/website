<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galaxy Recording Co. | Professional Music Production & Mastering</title>
    <meta name="description" content="Galaxy Recording Co. offers top-tier recording, mixing, and mastering services. Founded in 2025, we bring your sound to the universe. Book your session today.">
    <meta name="keywords" content="recording studio, mixing and mastering, professional music production, artist development">
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

    <header class="site-header">
        <div class="nav-container">
            <div class="logo">
                <span class="neon-text">GALAXY</span> RECORDING CO.
                <span class="est">Since 2025</span>
            </div>
            <nav class="main-nav">
                <a href="#home">Home</a>
                <a href="#about">About</a>
                <a href="#services">Services</a>
                <a href="#portfolio">Works</a>
                <a href="#contact">Contact</a>
            </nav>
            <div class="nav-actions">
                <button id="theme-toggle" aria-label="Toggle Dark/Light Mode">🌓</button>
                <a href="#contact" class="btn btn-primary">Book Now</a>
            </div>
        </div>
    </header>

    <section id="home" class="hero-section">
        <div class="video-overlay"></div>
        <video autoplay muted loop playsinline class="hero-video">
            </video>
        
        <div class="hero-content">
            <h1>Your Sound,<br><span class="neon-text">Our Universe.</span></h1>
            <p>Elevating artists with world-class recording, mixing, and mastering.</p>
            <div class="hero-btns">
                <a href="#contact" class="btn btn-primary btn-large">Book Your Session Today</a>
                <a href="#portfolio" class="btn btn-secondary btn-large">Listen to Portfolio</a>
            </div>
            <div class="trust-badges">
                <span>✔️ Professional Engineers</span>
                <span>✔️ State-of-the-art Gear</span>
                <span>✔️ Hundreds of Projects Completed</span>
            </div>
        </div>
    </section>

    <section id="services" class="section">
        <div class="container">
            <h2 class="section-title">Our Services</h2>
            <div class="grid services-grid">
                <div class="card service-card">
                    <h3>Recording</h3>
                    <p>Crystal clear multi-track recording in our acoustically treated live rooms.</p>
                    <a href="#contact" class="text-link">Book Now &rarr;</a>
                </div>
                <div class="card service-card">
                    <h3>Mixing</h3>
                    <p>Balancing and enhancing your tracks for width, depth, and punch.</p>
                    <a href="#contact" class="text-link">Book Now &rarr;</a>
                </div>
                <div class="card service-card">
                    <h3>Mastering</h3>
                    <p>The final polish to ensure your tracks translate perfectly on all streaming platforms.</p>
                    <a href="#contact" class="text-link">Book Now &rarr;</a>
                </div>
                <div class="card service-card">
                    <h3>Production</h3>
                    <p>Beatmaking, vocal tuning, and full-scale arrangements to bring your vision to life.</p>
                    <a href="#contact" class="text-link">Book Now &rarr;</a>
                </div>
            </div>
        </div>
    </section>

    <section id="portfolio" class="section dark-bg">
        <div class="container">
            <h2 class="section-title">Featured Works</h2>
            <div class="grid portfolio-grid">
                <div class="card portfolio-card">
                    <div class="portfolio-image placeholder-img">Project Alpha Cover</div>
                    <div class="portfolio-content">
                        <h3>Project Alpha</h3>
                        <p class="client-name">Client: The Supernovas</p>
                        <p>Full Album Production & Mixing.</p>
                        <audio controls class="audio-player">
                            Your browser does not support the audio element.
                        </audio>
                    </div>
                </div>
                <div class="card portfolio-card">
                    <div class="portfolio-image placeholder-img">Nebula EP Cover</div>
                    <div class="portfolio-content">
                        <h3>Nebula EP</h3>
                        <p class="client-name">Client: Sarah Jenkins</p>
                        <p>Vocal Recording & Mastering.</p>
                        <audio controls class="audio-player">
                            Your browser does not support the audio element.
                        </audio>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="section">
        <div class="container">
            <h2 class="section-title">About the Studio</h2>
            <div class="about-content">
                <div class="mission">
                    <h3>Our Mission</h3>
                    <p>Founded in 2025, Galaxy Recording Co. was built on an artist-first philosophy. We combine industry-leading analog gear with cutting-edge digital workflows to create a zero-compromise sonic environment. Whether you're recording your first demo or mastering your third studio album, we treat every project with cosmic importance.</p>
                </div>
                <div class="team-grid grid">
                    <div class="team-member">
                        <div class="team-photo placeholder-img">Photo</div>
                        <h4>Alex Vance</h4>
                        <p>Lead Audio Engineer</p>
                    </div>
                    <div class="team-member">
                        <div class="team-photo placeholder-img">Photo</div>
                        <h4>Mia Torres</h4>
                        <p>Senior Producer</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section contact-section">
        <div class="container">
            <h2 class="section-title">Initiate Contact</h2>
            <div class="contact-wrapper">
                <form id="booking-form" class="booking-form">
                    <div class="form-group">
                        <label for="name">Name / Artist Name</label>
                        <input type="text" id="name" required placeholder="John Doe">
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" required placeholder="john@example.com">
                    </div>
                    <div class="form-group">
                        <label for="project-type">Project Type</label>
                        <select id="project-type">
                            <option value="recording">Recording Session</option>
                            <option value="mixing">Mixing</option>
                            <option value="mastering">Mastering</option>
                            <option value="production">Full Production</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Project Details & Preferred Dates</label>
                        <textarea id="message" rows="5" required placeholder="Tell us about your sound..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Send Transmission (Book Session)</button>
                    <p class="microcopy">We aim to respond to all inquiries within 24 hours.</p>
                </form>

                <div class="contact-info">
                    <h3>Studio Coordinates</h3>
                    <p>📧 info@galaxyrecording.co</p>
                    <p>📞 +1 (555) 019-2025</p>
                    <div class="map-placeholder placeholder-img">
                        Google Maps Embed Placeholder
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="site-footer">
        <div class="container footer-content">
            <div class="footer-brand">
                <h3>Galaxy Recording Co.</h3>
                <p>Your Sound, Our Universe.</p>
            </div>
            <div class="footer-links">
                <a href="#faq">FAQ</a>
                <a href="#privacy">Privacy Policy (GDPR)</a>
                <a href="#blog">Resources</a>
            </div>
            <div class="social-links">
                <a href="#">Instagram</a>
                <a href="#">TikTok</a>
                <a href="#">YouTube</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 Galaxy Recording Co. All rights reserved.</p>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
